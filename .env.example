# Optional: if provided, the system uses OpenAI for answer generation.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Otherwise a local fallback model is used.
# Public options: Qwen/Qwen2.5-0.5B-Instruct (light), Qwen/Qwen2.5-1.5B-Instruct, Qwen/Qwen2.5-7B-Instruct
LOCAL_LLM_MODEL=Qwen/Qwen2.5-0.5B-Instruct

# Embedding and vision models
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
VLM_MODEL=Salesforce/blip-image-captioning-base

# Vector store configuration
CHROMA_DIR=./data/chroma
COLLECTION_NAME=multimodal_rag
RETRIEVAL_K=6

# OCR fallback for scanned PDFs (requires system package: tesseract-ocr)
ENABLE_OCR_FALLBACK=true
OCR_DPI=220

# Device for all torch/transformers models.
# Leave unset (or set to 'auto') to auto-detect: cuda > mps > cpu
# Set to 'cuda' in Google Colab (Runtime > Change runtime type > T4 GPU)
# or any other CUDA-enabled machine to get ~2-4x faster ingestion via fp16.
DEVICE=auto
