# Optional: if provided, the system uses OpenAI for answer generation.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Otherwise a local fallback model is used.
LOCAL_LLM_MODEL=google/flan-t5-base

# Embedding and vision models
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
VLM_MODEL=Salesforce/blip-image-captioning-base

# Vector store configuration
CHROMA_DIR=./data/chroma
COLLECTION_NAME=multimodal_rag
RETRIEVAL_K=6

# OCR fallback for scanned PDFs (requires system package: tesseract-ocr)
ENABLE_OCR_FALLBACK=true
OCR_DPI=220
